                },
                {
                    "id": "modal_03",
                    "base": "They [can] swim in the pool.",
                    "cue": "替换为 must not (mustn't)",
                    "expected": "They must not swim in the pool.",
                    "hint_cn": "must not 表示禁止"
                }
            ]
        },
        {
            "id": "modal_response",

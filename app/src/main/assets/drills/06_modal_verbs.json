{
    "grammar_point": "情态动词 (can/must/should)",
    "grammar_point_en": "Modal Verbs (Can/Must/Should)",
    "sets": [
        {
            "id": "modal_sub",
            "grammar_point": "情态动词 can/must",
            "grammar_point_en": "Modal Verbs - Can / Must",
            "drill_type": "substitution",
            "difficulty": 1,
            "instructions_cn": "替换句中情态动词，注意语法不变",
            "progress_label": "替换练习",
            "steps": [
                {
                    "id": "modal_01",
                    "base": "You [can] speak English well.",
                    "cue": "替换为 must（必须）",
                    "expected": "You must speak English well.",
                    "hint_cn": "情态动词后接动词原形"
                },
                {
                    "id": "modal_02",
                    "base": "He [must] finish his homework.",
                    "cue": "替换为 can（可以）",
                    "expected": "He can finish his homework.",
                    "hint_cn": "can 和 must 后都接动词原形"
                },
                {
                    "id": "modal_03",
                    "base": "They [can] swim in the pool.",
                    "cue": "替换为 must not (mustn't)",
                    "expected": "They must not swim in the pool.",
                    "hint_cn": "must not 表示禁止"
                }
            ]
        },
        {
            "id": "modal_response",
            "grammar_point": "情态动词 can/must",
            "grammar_point_en": "Modal Verbs - Can / Must",
            "drill_type": "response",
            "difficulty": 1,
            "instructions_cn": "完整回答下列问题",
            "progress_label": "问答练习",
            "steps": [
                {
                    "id": "modal_04",
                    "base": "Can you play the guitar?",
                    "cue": "肯定回答",
                    "expected": "Yes, I can play the guitar.",
                    "hint_cn": "肯定回答: Yes, 主语 + can"
                },
                {
                    "id": "modal_05",
                    "base": "Must I wear a uniform at school?",
                    "cue": "肯定回答",
                    "expected": "Yes, you must wear a uniform at school.",
                    "hint_cn": "肯定回答: Yes, you must..."
                }
            ]
        },
        {
            "id": "modal_trans",
            "grammar_point": "情态动词 (can/must/should)",
            "grammar_point_en": "Modal Verbs (Can/Must/Should)",
            "drill_type": "transformation",
            "difficulty": 2,
            "instructions_cn": "将下列句子改为否定句或一般疑问句",
            "progress_label": "转换练习",
            "steps": [
                {
                    "id": "modal_06",
                    "base": "I can go to the party.",
                    "cue": "改为否定句",
                    "expected": "I cannot go to the party.",
                    "hint_cn": "can 的否定式是 cannot / can't"
                },
                {
                    "id": "modal_07",
                    "base": "He must finish the report today.",
                    "cue": "改为否定句",
                    "expected": "He must not finish the report today.",
                    "hint_cn": "must 的否定式是 must not / mustn't"
                },
                {
                    "id": "modal_08",
                    "base": "You should see a doctor.",
                    "cue": "改为否定句",
                    "expected": "You should not see a doctor.",
                    "hint_cn": "should 的否定式是 should not / shouldn't"
                },
                {
                    "id": "modal_09",
                    "base": "She can swim across the river.",
                    "cue": "改为一般疑问句",
                    "expected": "Can she swim across the river?",
                    "hint_cn": "将 can 提到主语前"
                },
                {
                    "id": "modal_10",
                    "base": "We must leave before 6 o'clock.",
                    "cue": "改为一般疑问句",
                    "expected": "Must we leave before 6 o'clock?",
                    "hint_cn": "将 must 提到主语前"
                }
            ]
        },
        {
            "id": "modal_exp",
            "grammar_point": "情态动词 (can/must/should)",
            "grammar_point_en": "Modal Verbs (Can/Must/Should)",
            "drill_type": "expansion",
            "difficulty": 3,
            "instructions_cn": "给句子添加成分以扩展内容",
            "progress_label": "扩展练习",
            "steps": [
                {
                    "id": "modal_11",
                    "base": "You should study.",
                    "cue": "加目的 (for the exam)",
                    "expected": "You should study for the exam.",
                    "hint_cn": "介词短语放在句末"
                },
                {
                    "id": "modal_12",
                    "base": "He can speak.",
                    "cue": "加语言 (Chinese and English)",
                    "expected": "He can speak Chinese and English.",
                    "hint_cn": "宾语放在动词后"
                },
                {
                    "id": "modal_13",
                    "base": "I must go.",
                    "cue": "加时间 (now)",
                    "expected": "I must go now.",
                    "hint_cn": "时间副词放在句末"
                },
                {
                    "id": "modal_14",
                    "base": "She should eat.",
                    "cue": "加内容 (more vegetables)",
                    "expected": "She should eat more vegetables.",
                    "hint_cn": "宾语放在动词后"
                },
                {
                    "id": "modal_15",
                    "base": "They can stay.",
                    "cue": "加地点 (at home today)",
                    "expected": "They can stay at home today.",
                    "hint_cn": "地点和时间放在句末"
                }
            ]
        }
    ]
}

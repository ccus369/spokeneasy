                },
                {
                    "id": "be_02",
                    "base": "He [is] from China.",
                    "cue": "主语换成 They",
                    "expected": "They are from China.",
                    "hint_cn": "复数主语用 are"
                },
                {
                    "id": "be_03",
                    "base": "We [are] happy.",
                    "cue": "主语换成 She",
                    "expected": "She is happy.",
                    "hint_cn": "第三人称单数用 is"
                }
            ]
        },
        {
            "id": "be_response",
            "grammar_point": "be 动词 (am/is/are)",

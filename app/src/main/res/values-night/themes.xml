<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Spokeneasy" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary — Indigo (dark) -->
        <item name="colorPrimary">@color/indigo_200</item>
        <item name="colorOnPrimary">@color/indigo_800</item>
        <item name="colorPrimaryContainer">@color/indigo_700</item>
        <item name="colorOnPrimaryContainer">@color/indigo_50</item>

        <!-- Secondary — Indigo 500 (dark) -->
        <item name="colorSecondary">@color/indigo_200</item>
        <item name="colorOnSecondary">@color/indigo_800</item>
        <item name="colorSecondaryContainer">@color/indigo_700</item>
        <item name="colorOnSecondaryContainer">@color/indigo_100</item>

        <!-- Tertiary — Green CTA (dark) -->
        <item name="colorTertiary">@color/green_100</item>
        <item name="colorOnTertiary">@color/green_500</item>
        <item name="colorTertiaryContainer">@color/green_500</item>
        <item name="colorOnTertiaryContainer">@color/white</item>

        <!-- Background & Surface — OLED Dark -->
        <item name="android:colorBackground">@color/surface_oled</item>
        <item name="colorOnBackground">@color/grey_50</item>
        <item name="colorSurface">@color/surface_card_dark</item>
        <item name="colorOnSurface">@color/grey_50</item>
        <item name="colorSurfaceVariant">@color/surface_border_dark</item>
        <item name="colorOnSurfaceVariant">@color/indigo_100</item>

        <!-- Error -->
        <item name="colorError">@color/red_300</item>
        <item name="colorOnError">@color/red_900</item>

        <!-- Custom attrs — Indigo Bento surface levels (dark / OLED) -->
        <item name="surfaceCard">@color/surface_card_dark</item>
        <item name="surfaceBorder">@color/surface_border_dark</item>
        <item name="surfaceElevated">@color/surface_elevated_dark</item>
        <item name="colorCta">@color/green_500</item>
        <item name="colorOnCta">@color/white</item>

        <!-- Toolbar background — dark indigo -->
        <item name="toolbarBackground">@color/indigo_700</item>

        <!-- Custom attrs — icon gradient backgrounds (dark) -->
        <item name="iconBgIndigo">@drawable/bg_icon_indigo_dark</item>
        <item name="iconBgGreen">@drawable/bg_icon_green_dark</item>
        <item name="iconBgAmber">@drawable/bg_icon_amber_dark</item>
        <item name="iconBgPink">@drawable/bg_icon_pink_dark</item>
        <item name="iconBgPurple">@drawable/bg_icon_purple_dark</item>
        <item name="iconBgBlue">@drawable/bg_icon_blue_dark</item>

        <!-- Font families -->
        <item name="fontHeading">@font/outfit</item>
        <item name="fontBody">@font/work_sans</item>

        <!-- Status bar — transparent on OLED -->
        <item name="android:statusBarColor">@color/surface_oled</item>
        <item name="android:navigationBarColor">@color/surface_card_dark</item>
    </style>

    <style name="Theme.Spokeneasy" parent="Base.Theme.Spokeneasy" />
</resources>

<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Spokeneasy" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary — Indigo -->
        <item name="colorPrimary">@color/indigo_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/indigo_50</item>
        <item name="colorOnPrimaryContainer">@color/indigo_900</item>

        <!-- Secondary — Indigo 500 -->
        <item name="colorSecondary">@color/indigo_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/indigo_100</item>
        <item name="colorOnSecondaryContainer">@color/indigo_800</item>

        <!-- Tertiary — Green CTA -->
        <item name="colorTertiary">@color/green_500</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/green_100</item>
        <item name="colorOnTertiaryContainer">@color/green_500</item>

        <!-- Background & Surface — Light -->
        <item name="android:colorBackground">@color/grey_50</item>
        <item name="colorOnBackground">@color/grey_950</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/grey_950</item>
        <item name="colorSurfaceVariant">@color/indigo_50</item>
        <item name="colorOnSurfaceVariant">@color/indigo_800</item>

        <!-- Error -->
        <item name="colorError">@color/red_700</item>
        <item name="colorOnError">@color/white</item>

        <!-- Custom attrs — Indigo Bento surface levels (light) -->
        <item name="surfaceCard">@color/white</item>
        <item name="surfaceBorder">#FFE5E7EB</item>
        <item name="surfaceElevated">@color/white</item>
        <item name="colorCta">@color/green_500</item>
        <item name="colorOnCta">@color/white</item>

        <!-- Custom attrs — icon gradient backgrounds -->
        <item name="iconBgIndigo">@drawable/bg_icon_indigo</item>
        <item name="iconBgGreen">@drawable/bg_icon_green</item>
        <item name="iconBgAmber">@drawable/bg_icon_amber</item>
        <item name="iconBgPink">@drawable/bg_icon_pink</item>
        <item name="iconBgPurple">@drawable/bg_icon_purple</item>
        <item name="iconBgBlue">@drawable/bg_icon_blue</item>

        <!-- Font families -->
        <item name="fontHeading">@font/outfit</item>
        <item name="fontBody">@font/work_sans</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/indigo_600</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.Spokeneasy" parent="Base.Theme.Spokeneasy" />
</resources>

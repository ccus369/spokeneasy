<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Spokeneasy" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blue_100</item>
        <item name="colorOnPrimaryContainer">@color/blue_800</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/blue_grey_600</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/blue_grey_200</item>
        <item name="colorOnSecondaryContainer">@color/blue_grey_900</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/purple_800</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/grey_50</item>
        <item name="colorOnBackground">@color/grey_950</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/grey_950</item>

        <!-- Error -->
        <item name="colorError">@color/red_700</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/blue_700</item>
    </style>

    <style name="Theme.Spokeneasy" parent="Base.Theme.Spokeneasy" />
</resources>

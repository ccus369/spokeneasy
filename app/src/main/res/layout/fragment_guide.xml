<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.GuideFragment">

    <!-- Hero section (upper ~38%) -->
    <LinearLayout
        android:id="@+id/hero_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="?attr/colorPrimaryContainer"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.38">

        <TextView
            android:id="@+id/guide_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimaryContainer" />

        <TextView
            android:id="@+id/guide_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_subtitle"
            android:textSize="20sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:alpha="0.85" />

    </LinearLayout>

    <!-- Content section (remaining ~62%) -->
    <LinearLayout
        android:id="@+id/content_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="?android:colorBackground"
        android:paddingHorizontal="32dp"
        android:paddingTop="36dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/hero_panel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Feature 1 -->
        <LinearLayout
            android:id="@+id/guide_feature_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:background="@drawable/bg_icon_indigo"
                android:src="@drawable/ic_book_outline"
                android:contentDescription=""
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="@string/guide_feature_1"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnBackground" />

        </LinearLayout>

        <!-- Feature 2 -->
        <LinearLayout
            android:id="@+id/guide_feature_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:background="@drawable/bg_icon_blue"
                android:src="@drawable/ic_headphone_outline"
                android:contentDescription=""
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="@string/guide_feature_2"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnBackground" />

        </LinearLayout>

        <!-- Feature 3 -->
        <LinearLayout
            android:id="@+id/guide_feature_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:background="@drawable/bg_icon_green"
                android:src="@drawable/ic_mic_outline"
                android:contentDescription=""
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="@string/guide_feature_3"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnBackground" />

        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Permission hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/guide_permission_hint"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <!-- Full-width pill button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/guide_btn_start"
            android:textSize="18sp"
            app:cornerRadius="@dimen/corner_pill" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_large"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/surfaceBorder"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: gradient icon + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/tile_icon"
                android:layout_width="@dimen/icon_container_bento"
                android:layout_height="@dimen/icon_container_bento"
                android:padding="10dp"
                android:contentDescription="@null"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tile_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:fontFamily="@font/outfit"
                android:textColor="?attr/colorOnBackground" />

        </LinearLayout>

        <!-- Subtitle (indented to align with title, not icon) -->
        <TextView
            android:id="@+id/tile_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="56dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- Progress section (indented to align with subtitle) -->
        <LinearLayout
            android:id="@+id/tile_progress_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/tile_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tile_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:minWidth="40dp"
                android:gravity="end" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
